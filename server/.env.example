# Server Configuration
PORT=5000

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173

# Better Auth Secret - Generate a strong random secret for production
# You can generate one using: openssl rand -base64 32
BETTER_AUTH_SECRET=your-better-auth-secret-change-this-in-production
BETTER_AUTH_URL=http://localhost:5000

# Database Configuration
# Format: mysql://username:password@host:port/database
# NOTE: If your password contains special characters, URL-encode them:
# < becomes %3C, > becomes %3E, & becomes %26, etc.
# Example: mysql://root:my%3Cpass%3Eword@localhost:3306/casino
DATABASE_URL=mysql://root:password@localhost:3306/casino
