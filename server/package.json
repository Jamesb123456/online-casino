{
  "name": "online-casino-server",
  "version": "1.0.0",
  "description": "Backend server for the Platinum Casino Platform",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "start:ts": "node --loader ts-node/esm server.ts",
    "dev": "bun run --watch server.ts",
    "dev:full": "nodemon --exec \"node --loader ts-node/esm\" server.ts",
    "dev:js": "nodemon server.js",
    "lint": "eslint . --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "seed": "node --loader ts-node/esm scripts/seedDatabase.ts",
    "init-stats": "node --loader ts-node/esm scripts/initGameStats.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@socket.io/redis-adapter": "^8.3.0",
    "@types/compression": "^1.8.1",
    "bcryptjs": "^2.4.3",
    "better-auth": "^1.5.6",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "decimal.js": "^10.6.0",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.45.1",
    "express": "^4.21.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "ioredis": "^5.10.1",
    "morgan": "^1.10.0",
    "mysql2": "^3.6.3",
    "socket.io": "^4.8.1",
    "validator": "^13.11.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/helmet": "^0.0.48",
    "@types/morgan": "^1.9.10",
    "@types/node": "^24.0.4",
    "@types/supertest": "^7.2.0",
    "@types/validator": "^13.15.2",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitest/coverage-v8": "^4.1.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^8.57.1",
    "nodemon": "^3.0.2",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "vitest": "^4.1.2"
  }
}
