{
  "name": "online-casino-server",
  "version": "1.0.0",
  "description": "Backend server for the Platinum Casino Platform",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "start:ts": "node --loader ts-node/esm server.ts",
    "dev": "nodemon --exec \"node --loader ts-node/esm\" server.ts",
    "dev:full": "nodemon --exec \"node --loader ts-node/esm\" server.ts",
    "dev:js": "nodemon server.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "seed": "node --loader ts-node/esm scripts/seedDatabase.ts",
    "init-stats": "node --loader ts-node/esm scripts/initGameStats.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.32.0",
    "express": "^4.21.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "mysql2": "^3.6.3",
    "socket.io": "^4.8.1",
    "validator": "^13.11.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/helmet": "^0.0.48",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^24.0.4",
    "@types/validator": "^13.15.2",
    "drizzle-kit": "^0.23.0",
    "nodemon": "^3.0.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
